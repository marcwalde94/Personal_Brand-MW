# YouTube-Wochen-Briefing — Umgebungsvariablen
# Kopieren nach  .env  und ausfüllen.  .env ist in .gitignore (wird NIE committet).

# --- YouTube Data API v3 ---------------------------------------------------
# Holen: https://console.cloud.google.com  ->  Projekt anlegen
#  -> "APIs & Dienste" -> "YouTube Data API v3" aktivieren
#  -> "Anmeldedaten" -> "API-Schlüssel erstellen"
YOUTUBE_API_KEY=

# --- Anthropic / Claude ----------------------------------------------------
# Holen: https://console.anthropic.com  -> API Keys
ANTHROPIC_API_KEY=
# Optional: Modell überschreiben (Default claude-opus-4-8).
# Günstiger im Wochenbetrieb: claude-sonnet-4-6
CLAUDE_MODEL=claude-opus-4-8

# --- E-Mail-Versand (SMTP) -------------------------------------------------
# Gmail-Beispiel: App-Passwort erzeugen (NICHT das normale Passwort!):
#   https://myaccount.google.com/apppasswords  (2FA muss aktiv sein)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=dein.name@gmail.com
SMTP_PASS=app-passwort-16-zeichen
SMTP_FROM=dein.name@gmail.com      # optional, sonst = SMTP_USER
SMTP_TO=dein.name@gmail.com        # Empfänger; optional, sonst = SMTP_USER
