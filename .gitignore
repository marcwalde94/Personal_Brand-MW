# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...aber die Briefing-Vorlage MUSS getrackt sein (sonst fehlt sie beim Auschecken):
!youtube-briefing/.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# youtube-briefing (Python pipeline)
__pycache__/
*.pyc
youtube-briefing/.venv/
# Hinweis: youtube-briefing/seen.json wird ABSICHTLICH getrackt — der
# GitHub-Actions-Workflow committet es zurück, damit Videos nicht doppelt kommen.
